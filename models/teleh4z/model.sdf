      </inertial>

      <visual name="buoyancy_shell_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>meshes/buoyancy_shell_colored.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <collision name="shell_buoyancy_collision">
        <pose>0 0 0.05 0 0 0</pose>
        <geometry>
          <box>
            <size>0.24 0.16 0.0408854167</size>
          </box>
        </geometry>
      </collision>
    </link>

    <joint name="buoyancy_shell_joint" type="fixed">
      <parent>base_link</parent>
      <child>buoyancy_shell_link</child>
    </joint>

    <link name="camera_link">
      <pose relative_to="base_link">0.144 0 -0.0148 0 0 0</pose>
      <inertial>
        <mass>1e-4</mass>
        <inertia>
          <ixx>1e-8</ixx>
          <iyy>1e-8</iyy>
          <izz>1e-8</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
