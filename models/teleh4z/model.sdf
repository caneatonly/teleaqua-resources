          <diffuse>0.035 0.035 0.035 1</diffuse>
          <specular>0.98 0.98 0.98 1</specular>
          <emissive>0.005 0.005 0.005 1</emissive>
        </material>
      </visual>
    </link>

    <joint name="waterprop_front_joint" type="revolute">
      <parent>base_link</parent>
      <child>waterprop_front_link</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>10</effort>
          <velocity>1000</velocity>
        </limit>
        <dynamics>
          <damping>0.001</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="waterprop_back_link">
      <pose relative_to="base_link">-0.10643 0 0.04 0 1.57079632679 0</pose>
      <inertial>
        <mass>1e-4</mass>
        <inertia>
          <ixx>1e-8</ixx>
          <iyy>1e-8</iyy>
          <izz>1e-8</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="waterprop_back_visual">
