    <plugin filename="gz-sim-bidir-motor-model-system" name="gz::sim::v8::systems::BiDirectionalMotorModel">
      <jointName>waterprop_right_joint</jointName>
      <linkName>waterprop_right_link</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <motorConstant>9.6065e-07</motorConstant>
      <momentConstant>-3.318e-10</momentConstant>
      <commandSubTopic>servo_0</commandSubTopic>
      <motorNumber>0</motorNumber>
      <thrustAxis>1 0 0</thrustAxis>
      <commandGain>57.29</commandGain>
      <deadbandOmega>10</deadbandOmega>
      <maxOmega>3500</maxOmega>
      <maxThrust>15</maxThrust>
      <maxTorque>1.5</maxTorque>
      <forwardCoeff>1.0</forwardCoeff>
      <reverseCoeff>0.86</reverseCoeff>
      <surface_z>0.0</surface_z>
      <transition_band>0.08</transition_band>
      <fluid_density_water>1000.0</fluid_density_water>
      <fluid_density_air>1.225</fluid_density_air>
      <sample_point>0 0 0</sample_point>
      <sample_point>0 0.018 0</sample_point>
      <sample_point>0 -0.018 0</sample_point>
      <sample_point>0 0 0.018</sample_point>
