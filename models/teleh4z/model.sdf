    </plugin>

    <plugin filename="/home/user/external/plugins/hydrodynamics/build/libhydrodynamics.so" name="zyshine3_gz_plugins::HybridHydrodynamics">
      <hydrodynamics>
        <link_name>base_link</link_name>
        <surface_z>0.0</surface_z>
        <transition_band>0.1</transition_band>
        <fluid_density_water>1000.0</fluid_density_water>
        <fluid_density_air>1.225</fluid_density_air>
        <default_current>0 0 0</default_current>
        <air_clearance_margin>-0.02</air_clearance_margin>
        <!-- 浸沒比例采样点可以进一步优化 -->
        <sample_point>0.16 0.0 0.06</sample_point>
        <sample_point>0.16 0.0 -0.02</sample_point>
        <sample_point>0.06 0.12 0.05</sample_point>
        <sample_point>0.06 -0.12 0.05</sample_point>
        <sample_point>0.00 0.0 0.08</sample_point>
        <sample_point>0.00 0.0 -0.04</sample_point>
        <sample_point>-0.10 0.12 0.04</sample_point>
        <sample_point>-0.10 -0.12 0.04</sample_point>
        <sample_point>-0.14 0.0 -0.01</sample_point>

        <water_thruster_link_name>waterprop_right_link</water_thruster_link_name>
        <water_thruster_link_name>waterprop_front_link</water_thruster_link_name>
        <water_thruster_link_name>waterprop_left_link</water_thruster_link_name>
        <water_thruster_link_name>waterprop_back_link</water_thruster_link_name>

        <air_prop_link_name>airprop_rightfront_link</air_prop_link_name>
        <air_prop_link_name>airprop_leftfront_link</air_prop_link_name>
        <air_prop_link_name>airprop_leftback_link</air_prop_link_name>
        <air_prop_link_name>airprop_rightback_link</air_prop_link_name>

        <!-- HybridHydrodynamics v2 ：插件侧附加质量与附加质量科氏项。
             这里沿用传统水动力学导数符号约定，内部会按正幅值使用。 -->
        <enable_added_mass>true</enable_added_mass>
        <enable_added_mass_coriolis>true</enable_added_mass_coriolis>
        <xDotU>-0.01</xDotU>
        <yDotV>-0.02</yDotV>
        <zDotW>-0.01</zDotW>
        <kDotP>-0.08</kDotP>
        <mDotQ>-0.04</mDotQ>
        <nDotR>-0.02</nDotR>

        <!-- HybridHydrodynamics v2 新增：加速度估计滤波、限幅与 jerk 限制。
             这些是首版稳定性占位参数，后续可以结合日志继续调参。 -->
        <added_mass_velocity_filter_tau>0.03</added_mass_velocity_filter_tau>
        <added_mass_accel_filter_tau>0.06</added_mass_accel_filter_tau>
        <added_mass_linear_accel_limit>4.0</added_mass_linear_accel_limit>
        <added_mass_angular_accel_limit>8.0</added_mass_angular_accel_limit>
        <added_mass_linear_jerk_limit>20.0</added_mass_linear_jerk_limit>
        <added_mass_angular_jerk_limit>40.0</added_mass_angular_jerk_limit>
        <added_mass_reset_scale_threshold>0.05</added_mass_reset_scale_threshold>

        <!-- HybridHydrodynamics v2 阻尼参数：仍保留线性项与 abs 二次项。 -->
        <xU>-12.0</xU>
        <xUabsU>-15.0</xUabsU>
        <yV>-25.0</yV>
        <yVabsV>-65.0</yVabsV>
        <zW>-25.0</zW>
        <zWabsW>-42.0</zWabsW>
        <kP>-5.2</kP>
        <kPabsP>-1.5</kPabsP>
        <mQ>-5.0</mQ>
        <mQabsQ>-9.0</mQabsQ>
        <nR>-4.5</nR>
        <nRabsR>-10.5</nRabsR>
      </hydrodynamics>
    </plugin>

    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>false</publish_link_pose>
      <publish_nested_model_pose>true</publish_nested_model_pose> 
      <publish_model_pose>true</publish_model_pose>
    </plugin>

  </model>
</sdf>
