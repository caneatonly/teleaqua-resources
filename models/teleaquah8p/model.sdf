    <joint name="rotor_8_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_8</child>
      <pose relative_to="base_link">-0.004 -0.093 0.003 0 0 0</pose>
      <axis><xyz>-1 0 0</xyz></axis>
    </joint>
    <link name="rotor_8">
      <pose relative_to="rotor_8_joint">0 0 0 0 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
      <visual name="rotor_8_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://teleaquah8/meshes/right_waterprop.stl</uri></mesh></geometry><material><diffuse>0 1 0 1</diffuse></material></visual>
    </link>
    <plugin filename="gz-sim-bidir-motor-model-system" name="gz::sim::v8::systems::BiDirectionalMotorModel">
      <jointName>rotor_8_joint</jointName>
      <linkName>rotor_8</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <motorConstant>9.6065e-07</motorConstant>
      <momentConstant>-3.318e-10</momentConstant>
      <commandSubTopic>servo_0</commandSubTopic>
      <motorNumber>0</motorNumber>
      <thrustAxis>-1 0 0</thrustAxis>
      <commandGain>57.29</commandGain>
      <deadbandOmega>10</deadbandOmega>
      <maxOmega>3500</maxOmega>
      <maxThrust>15</maxThrust>
      <maxTorque>1.5</maxTorque>
      <forwardCoeff>1.0</forwardCoeff>
      <reverseCoeff>0.86</reverseCoeff>
    </plugin>

    <joint name="rotor_9_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_9</child>
      <pose relative_to="base_link">0.159 0 0.017 0 0 0</pose>
      <axis><xyz>0 0 -1</xyz></axis>
    </joint>
    <link name="rotor_9">
      <pose relative_to="rotor_9_joint">0 0 0 0 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
      <visual name="rotor_9_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://teleaquah8/meshes/front_waterprop.stl</uri></mesh></geometry><material><diffuse>0 1 0 1</diffuse></material></visual>
