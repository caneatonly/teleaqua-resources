      <visual name="rotor_10_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://teleaquah8/meshes/left_waterprop.stl</uri></mesh></geometry><material><diffuse>0 1 0 1</diffuse></material></visual>
    </link>
