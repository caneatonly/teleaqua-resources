    <joint name="rotor_11_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_11</child>
      <pose relative_to="base_link">-0.161 0. 0.017 0 0 0</pose>
      <axis><xyz>0 0 -1</xyz></axis>
    </joint>
    <link name="rotor_11">
      <pose relative_to="rotor_11_joint">0 0 0 0 0 0</pose>
      <inertial><mass>0.1</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial>
      <visual name="rotor_11_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://teleaquah8/meshes/back_waterprop.stl</uri></mesh></geometry><material><diffuse>0 1 0 1</diffuse></material></visual>
    </link>
    <plugin filename="gz-sim-bidir-motor-model-system" name="gz::sim::v8::systems::BiDirectionalMotorModel">
      <jointName>rotor_11_joint</jointName>
      <linkName>rotor_11</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <motorConstant>9.6065e-07</motorConstant>
      <momentConstant>-3.318e-10</momentConstant>
      <commandSubTopic>servo_3</commandSubTopic>
      <motorNumber>0</motorNumber>
      <thrustAxis>0 0 -1</thrustAxis>
      <commandGain>57.29</commandGain>
      <deadbandOmega>10</deadbandOmega>
      <maxOmega>3500</maxOmega>
      <maxThrust>15</maxThrust>
      <maxTorque>1.5</maxTorque>
      <forwardCoeff>1.0</forwardCoeff>
      <reverseCoeff>0.86</reverseCoeff>
    </plugin>
    <plugin filename="libbuoyancy" name="hippo_gz_plugins::buoyancy">
      <buoyancy>
        <!-- 必须配置：应用浮力的链接名称（与模型中定义的链接名一致） -->
        <link_name>base_link</link_name>

        <!-- 必须配置：额外叠加的恒定浮力（单位：N） -->
        <force_added>0.0</force_added>

        <!-- 必须配置：浮力对重力的补偿比例（1.0 表示完全抵消重力） -->
        <compensation>1.33</compensation>

        <!-- 必须配置：浮力作用点（相对于链接局部坐标系的原点） -->
        <origin>0 0.0 0.02</origin>

        <!-- 必须配置：水面附近浮力衰减的距离阈值（Z坐标高于此值时浮力线性衰减至0） -->
        <height_scale_limit>0.1</height_scale_limit>
      </buoyancy>
    </plugin>
    <plugin filename="libhydrodynamics" name="hippo_gz_plugins::hydrodynamics">
      <hydrodynamics>
        <link>base_link</link>

        <added_mass_linear>3.0 4.5 5.5</added_mass_linear>
        <added_mass_angular>0.1 0.1 0.2</added_mass_angular>

        <damping_linear>12.0 25.0 25.0</damping_linear>

        <damping_angular>5.0 5.0 8.0</damping_angular>
      </hydrodynamics>
    </plugin>
    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>false</publish_link_pose>
      <publish_nested_model_pose>true</publish_nested_model_pose>
      <publish_model_pose>true</publish_model_pose>  <!-- 显式启用模型位姿发布 -->
      <publish_pose_topic>/model/mcuuv_0/pose</publish_pose_topic>
    </plugin>
  </model>
</sdf>
