<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.9">
  <model name="teleaquah8">
    <!-- 虚拟世界链接：补充惯性（Gazebo必需） -->
    <!-- 使用 ball 关节直接连接到 world -->
    <!-- <joint name="world_base_joint" type="ball">
      <parent>world</parent>
      <child>base_link</child>
    </joint> -->


    <pose>0 0 0.5 0 0 0</pose>

    <link name="base_link">
      <gravity>1</gravity>
      <velocity_decay>
        <linear>0.1</linear>
        <angular>0.1</angular>
      </velocity_decay>

      <inertial>
        <mass>4.1</mass>
        <inertia>
          <ixx>0.07</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>

          <iyy>0.07</iyy>
          <iyz>0</iyz>

          <izz>0.10</izz>
        </inertia>
        <pose>0 0 -0.05 0 0 0</pose>
      </inertial>

      <visual name="base_visual">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://teleaquah8/meshes/model.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <collision name="base_collision">
        <geometry>
          <box><size>0.55 0.55 0.2</size></box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0.1</max_vel>
              <kp>100000.0</kp>
              <kd>100.0</kd>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>0.4</mu>
              <mu2>0.4</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <visualize>true</visualize>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
      <sensor name="magnetometer_sensor" type="magnetometer">
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <magnetometer>
          <x><noise type="gaussian"><stddev>0.0001</stddev></noise></x>
          <y><noise type="gaussian"><stddev>0.0001</stddev></noise></y>
          <z><noise type="gaussian"><stddev>0.0001</stddev></noise></z>
        </magnetometer>
      </sensor>
      <sensor name="air_pressure_sensor" type="air_pressure">
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <air_pressure>
          <pressure>
            <noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise>
          </pressure>
        </air_pressure>
      </sensor>
      <sensor name="navsat_sensor" type="navsat">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <pose relative_to="base_link">0.163 -0.187 0.061 0 0 0</pose>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <link name="rotor_0">
      <pose relative_to="rotor_0_joint">0 0 0 0 0 0</pose>
      <inertial><mass>0.113</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0002</izz></inertia></inertial>
      <visual name="rotor_0_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://teleaquah8/meshes/ccw_prop.stl</uri></mesh></geometry><material><diffuse>0 0 1 1</diffuse></material></visual>
    </link>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.015</timeConstantUp><timeConstantDown>0.03</timeConstantDown>
      <maxRotVelocity>1585</maxRotVelocity>
      <motorConstant>1.64e-05</motorConstant>
      <momentConstant>0.018</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>0.0001</rotorDragCoefficient><rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorType>velocity</motorType>
    </plugin>

    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <pose relative_to="base_link">0.163 0.187 0.061 0 0 0</pose>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <link name="rotor_1">
      <pose relative_to="rotor_1_joint">0 0 0 0 0 0</pose>
      <inertial><mass>0.113</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0002</izz></inertia></inertial>
      <visual name="rotor_1_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://teleaquah8/meshes/cw_prop.stl</uri></mesh></geometry><material><diffuse>1 0 0 1</diffuse></material></visual>
    </link>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.015</timeConstantUp><timeConstantDown>0.03</timeConstantDown>
      <maxRotVelocity>1585</maxRotVelocity>
      <motorConstant>1.64e-05</motorConstant>
      <momentConstant>0.018</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>0.0001</rotorDragCoefficient><rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorType>velocity</motorType>
    </plugin>

    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <pose relative_to="base_link">-0.166 0.187 0.061 0 0 0</pose>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <link name="rotor_2">
      <pose relative_to="rotor_2_joint">0 0 0 0 0 0</pose>
      <inertial><mass>0.113</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0002</izz></inertia></inertial>
      <visual name="rotor_2_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://teleaquah8/meshes/ccw_prop.stl</uri></mesh></geometry><material><diffuse>0 0 1 1</diffuse></material></visual>
    </link>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
